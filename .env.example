# Server
PORT=4173
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/etherfi_monitor

# Optimism is the only active monitor network.
OPTIMISM_RPC_URL=https://mainnet.optimism.io
CHAIN_ID=10

# Optional: replace the built-in chain list with a JSON array.
# CHAIN_CONFIGS_JSON=[{"name":"Optimism","chainId":10,"rpcUrl":"https://mainnet.optimism.io","etherFiSafeFactoryAddress":"0xF4e147Db314947fC1275a8CbB6Cde48c510cd8CF","debtManagerAddress":"0x0078C5a459132e279056B2371fE8A8eC973A9553","cashModuleAddress":"0x7Ca0b75E67E33c0014325B739A8d019C4FE445F0"}]

# EtherFi Cash V3 Optimism mainnet deployment.
DEBT_MANAGER_ADDRESS=0x0078C5a459132e279056B2371fE8A8eC973A9553
CASH_MODULE_ADDRESS=0x7Ca0b75E67E33c0014325B739A8d019C4FE445F0
ETHERFI_SAFE_FACTORY_ADDRESS=0xF4e147Db314947fC1275a8CbB6Cde48c510cd8CF
ETHERFI_SAFE_FACTORY_START_BLOCK=0
FACTORY_LOG_CHUNK_SIZE=5000

# Polling controls.
RPC_BATCH_SIZE=5
RPC_BATCH_DELAY_MS=250
HEALTH_STALE_AFTER_HOURS=24

# Worker controls.
ACTIVE_SAFE_LOOKBACK_HOURS=72
BORROW_DISCOVERY_INTERVAL_MS=300000
HEALTH_POLL_INTERVAL_MS=300000
HEALTH_POLL_BATCH_SIZE=25
WORKER_LEASE_TTL_MS=240000
ALERT_WORKER_INTERVAL_MS=300000
FRAUD_WATCH_WINDOW_MINUTES=60

# Optional PagerDuty Events API integration.
PAGERDUTY_INTEGRATION_KEY=
PAGERDUTY_EVENTS_URL=https://events.pagerduty.com/v2/enqueue
