# Server
PORT=4173
DATA_PATH=./data/etherfi-monitor.json

# Dune is used for broad, low-frequency discovery/reconciliation queries.
DUNE_API_KEY=
DUNE_SAFE_UNIVERSE_QUERY_ID=
DUNE_RECENT_ACTIVITY_QUERY_ID=
DUNE_AGGREGATES_QUERY_ID=
DUNE_PAGE_SIZE=1000

# Scroll RPC is used for current safe-health reads.
SCROLL_RPC_URL=https://rpc.scroll.io
CHAIN_ID=534352

# Contract addresses should be filled from the Cash V3 deployment artifacts.
# DEBT_MANAGER_ADDRESS is required for poll-health.
DEBT_MANAGER_ADDRESS=
CASH_MODULE_ADDRESS=

# Polling controls.
RPC_BATCH_SIZE=25
RPC_BATCH_DELAY_MS=250
HEALTH_STALE_AFTER_HOURS=24
