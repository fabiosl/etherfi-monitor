# Server
PORT=4173
DATA_PATH=./data/etherfi-monitor.json

# Scroll RPC is used for current safe-health reads.
SCROLL_RPC_URL=https://rpc.scroll.io
CHAIN_ID=534352

# EtherFi Cash V3 Scroll mainnet deployment:
# https://github.com/etherfi-protocol/cash-v3/blob/master/deployments/mainnet/534352/deployments.json
DEBT_MANAGER_ADDRESS=0x0078C5a459132e279056B2371fE8A8eC973A9553
CASH_MODULE_ADDRESS=0x7Ca0b75E67E33c0014325B739A8d019C4FE445F0
ETHERFI_SAFE_FACTORY_ADDRESS=0xF4e147Db314947fC1275a8CbB6Cde48c510cd8CF

# Polling controls.
RPC_BATCH_SIZE=25
RPC_BATCH_DELAY_MS=250
HEALTH_STALE_AFTER_HOURS=24
